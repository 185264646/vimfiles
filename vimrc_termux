" Phones have small screen
set tabstop=4
set shiftwidth=4

" remove /usr/include, add $PREFIX/include
" For Termux
set path-=/usr/include
set path+=$PREFIX/include

" YouCompleteMe settings
" Use system clangd rather than downloaded one
let g:ycm_clangd_binary_path="clangd"

imap <silent><C-L> <Plug>(YCMToggleSignatureHelp)

"netrw
" make lists tree-like
let g:netrw_liststyle=3
" disable banner
let g:netrw_banner=v:false
"
let g:netrw_browse_split=0
" set wdith to 25%
let g:netrw_winsize=25
